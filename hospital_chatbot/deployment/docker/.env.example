# LLM Settings (ollama | typhoon | openai)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=uph_chatbot

# API Keys (Required for cloud)
TYPHOON_API_KEY=
OPENAI_API_KEY=

# Embedding Settings (ollama | typhoon | hf)
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBED_MODEL=bge-m3:latest

# Admin Settings
ADMIN_AUTH_MODE=either
ADMIN_TOKEN=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
